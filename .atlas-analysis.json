  "keyFeatures": [
    "Interactive proposal builder with drag-and-drop itinerary management",
    "Multi-organization support with team collaboration and role-based access",
    "Tour template library with clone and customize capabilities",
    "Client management with proposal tracking and commenting",
    "PDF export and email sharing for proposals",
    "Content library for accommodations, activities, and national parks",
    "Real-time collaboration with comments and assignments",
    "Pricing calculator with customizable traveler groups and extras",
    "Authentication with Better Auth including passkey support",
    "Integrated with Polar.sh for subscription management"
  ],
